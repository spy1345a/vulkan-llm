#version 450

layout(set = 0, binding = 0) buffer BufA   { float a[]; };
layout(set = 0, binding = 1) buffer BufB   { float b[]; };
layout(set = 0, binding = 2) buffer BufOut { float result[]; };

layout(local_size_x = 256) in;

void main() {
    uint i = gl_GlobalInvocationID.x;
    result[i] = a[i] - b[i];
}
